@page "/register"
@using AuthFrontend.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager NavigationManager

<div style="max-width: 400px; margin: 50px auto; padding: 30px; border: 1px solid #ddd; border-radius: 8px; font-family: Arial, sans-serif;">
    <h2 style="text-align: center; margin-bottom: 20px;">Register</h2>

    @if (!string.IsNullOrEmpty(notification))
    {
        <div style="padding: 10px; margin-bottom: 15px; background-color: @(isSuccess ? "#d4edda" : "#f8d7da"); color: @(isSuccess ? "#155724" : "#721c24"); border-radius: 4px;">
            @notification
        </div>
    }

    <div style="margin-bottom: 15px;">
        <label style="display: block; margin-bottom: 5px;">Username Baru</label>
        <input @bind="authRequest.Username" type="text" style="width: 100%; padding: 8px; box-sizing: border-box;" />
    </div>
    
    <div style="margin-bottom: 20px;">
        <label style="display: block; margin-bottom: 5px;">Password Baru</label>
        <input @bind="authRequest.Password" type="password" style="width: 100%; padding: 8px; box-sizing: border-box;" />
    </div>
    
    <div style="display: flex; gap: 10px;">
        <button @onclick="SubmitRegister" style="flex: 1; padding: 10px; background-color: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer;">Submit Save</button>
        <button @onclick="GoToLogin" style="flex: 1; padding: 10px; background-color: #6c757d; color: white; border: none; border-radius: 4px; cursor: pointer;">Kembali</button>
    </div>
</div>

@code {
    private AuthRequest authRequest = new AuthRequest();
    private string notification = "";
    private bool isSuccess = false;

    private async Task SubmitRegister()
    {
        var response = await Http.PostAsJsonAsync("api/auth/register", authRequest);
        var result = await response.Content.ReadFromJsonAsync<AuthResponse>();

        if (result != null)
        {
            isSuccess = result.IsSuccess;
            notification = result.Message;

            if (isSuccess)
            {
                await Task.Delay(1500);
                NavigationManager.NavigateTo("/");
            }
        }
    }

    private void GoToLogin()
    {
        NavigationManager.NavigateTo("/");
    }
}