@page "/"
@using AuthFrontend.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager NavigationManager

<div style="max-width: 400px; margin: 50px auto; padding: 30px; border: 1px solid #ddd; border-radius: 8px; font-family: Arial, sans-serif;">
    <h2 style="text-align: center; margin-bottom: 20px;">Login</h2>
    
    @if (!string.IsNullOrEmpty(notification))
    {
        <div style="padding: 10px; margin-bottom: 15px; background-color: @(isSuccess ? "#d4edda" : "#f8d7da"); color: @(isSuccess ? "#155724" : "#721c24"); border-radius: 4px;">
            @notification
        </div>
    }

    <div style="margin-bottom: 15px;">
        <label style="display: block; margin-bottom: 5px;">Username</label>
        <input @bind="authRequest.Username" type="text" style="width: 100%; padding: 8px; box-sizing: border-box;" />
    </div>
    
    <div style="margin-bottom: 20px;">
        <label style="display: block; margin-bottom: 5px;">Password</label>
        <input @bind="authRequest.Password" type="password" style="width: 100%; padding: 8px; box-sizing: border-box;" />
    </div>
    
    <div style="display: flex; gap: 10px;">
        <button @onclick="SubmitLogin" style="flex: 1; padding: 10px; background-color: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer;">Login</button>
        <button @onclick="GoToRegister" style="flex: 1; padding: 10px; background-color: #6c757d; color: white; border: none; border-radius: 4px; cursor: pointer;">Register</button>
    </div>
</div>

@code {
    private AuthRequest authRequest = new AuthRequest();
    private int loginFailed = 0;
    private string notification = "";
    private bool isSuccess = false;

    private async Task SubmitLogin()
    {
        var response = await Http.PostAsJsonAsync("api/auth/login", authRequest);
        var result = await response.Content.ReadFromJsonAsync<AuthResponse>();

        if (result != null && result.IsSuccess)
        {
            isSuccess = true;
            notification = result.Message;
            
            NavigationManager.NavigateTo("/welcome");
        }
        else
        {
            loginFailed++; 
            isSuccess = false;
            notification = result?.Message ?? "Terjadi kesalahan server.";

            if (loginFailed > 3) 
            {
                NavigationManager.NavigateTo("/lockscreen");
            }
        }
    }

    private void GoToRegister()
    {
        NavigationManager.NavigateTo("/register");
    }
}